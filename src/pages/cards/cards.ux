    border-radius: 6dp;
    border-width: 0.5dp;
  }

  .placeholder-text {
    font-size: 60dp;
  }

  .card-front-wrapper {
    padding: 5dp;
  }

  .corner-rank {
    font-size: 16dp;
  }

  .corner-suit {
