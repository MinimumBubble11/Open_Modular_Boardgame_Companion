  width: 140px;
  height: 200px;
  border-radius: 8px;
  border: 1px solid #aaa;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 2px 5px rgba(0,0,0,.2);
  display: flex;
  justify-content: center;
  align-items: center;
}

