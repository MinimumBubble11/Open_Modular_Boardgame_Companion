  justify-content: flex-end;
}

.corner {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.bottom-right-corner {
  transform: rotate(180deg);
}

.corner-rank {
  font-size: 24px;
  font-weight: 700;
}

.corner-suit {
  width: 18px;
  height: 18px;
  margin-top: 2px;
}

.center-suit {
  width: 60px;
  height: 60px;
}

.red {
  color: #ff3b30;
}
