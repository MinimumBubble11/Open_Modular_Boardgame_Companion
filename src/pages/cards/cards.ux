  color: #000;
}

.action-button {
  width: 130px;
  height: 50px;
  border-radius: 15px;
  background-color: #333;
  font-size: 24px;
  color: #4ccfff;
  margin-top: 20px;
  margin-bottom: 50px;
}

/* ========== Xiaomi Watch S3 圆形小屏专用适配 ========== */
@media (shape: circle) and (min-width: 200) and (max-width: 260) {
  .tool-page {
    padding: 8dp 8dp 16dp 8dp;
  }

  .back-button {
    width: 53dp;
    height: 23dp;
