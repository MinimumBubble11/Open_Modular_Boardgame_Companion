<template>
  <scroll class="detail-page" scroll-y="true" bounces="true">
    <input class="back-button" type="button" value="< 返回" onclick="goBack" />
    <div class="section">
      <text class="section-title">原作者网页工具</text>
      <qrcode class="qr-code" value="https://andy5533.github.io/Open-Modular-Boardgame-Companion/PLAYGROUND/PLAYGROUND.html" style="color: #000;"></qrcode>
