    <div class="section">
      <text class="section-title">Github</text>
      <qrcode class="qr-code" value="https://github.com/MinimumBubble11/Open_Modular_Boardgame_Companion" style="color: #000;"></qrcode>
    </div>
    <div class="separator"></div>
    <div class="section">
      <text class="section-title">原项目Github</text>
      <qrcode class="qr-code" value="https://github.com/Andy5533/Open-Modular-Boardgame-Companion" style="color: #000;"></qrcode>
      <text class="section-title"> </text>
    </div>

    <!-- 开发者信息（含头像） -->
    <div class="section">
      <text class="developer-title">developers</text>
      <image class="avatar" src="/common/head.png" />
      <div class="developer-name">
        <text class="dev-char" style="color: #FF6B6B;">一</text>
        <text class="dev-char" style="color: #FFD93D;">棵</text>
        <text class="dev-char" style="color: #6BCB77;">桦</text>
        <text class="dev-char" style="color: #4D96FF;">树</text>
      </div>
      <text class="dev-char" style="color: #FF6B6B;"></text>
      <text class="developer-title">原作者</text>
      <image class="avatar" src="/common/BALALALAL.png" />
      <text class="section-title">BALALALAL</text>
    </div>

    <div class="section">
      <!-- 动态版本号：自动从应用信息中读取 -->
      <text class="section-title" style="color: #4ae0f0;">Version {{appVersion}}</text>
    </div>
  </scroll>
</template>

<script>
import router from "@system.router";
import vibrator from '@system.vibrator';
import app from '@system.app';   // 导入应用信息模块

export default {
  private: {
    appVersion: ''   // 存储自动获取的版本号
  },
  onInit() {
    // 自动查询并显示当前应用版本
    try {
      const info = app.getInfo();
      this.appVersion = info.versionName || '未知版本';
    } catch (err) {
      console.error('获取版本号失败：', err);
      this.appVersion = '获取失败';
    }
  },
  goBack() {
    vibrator.vibrate({ mode: 'short' });
    router.back();
  }
}
</script>

